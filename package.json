{
  "name": "pixel-agents-standalone",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:ui\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:ui": "cd webview-ui && vite",
    "build": "npm run build:server && npm run build:ui",
    "build:server": "esbuild server/index.ts --bundle --platform=node --format=esm --outfile=dist/server.js --external:chokidar --external:ws --external:express --external:pngjs",
    "build:ui": "cd webview-ui && pnpm exec vite build --outDir ../dist/public && cp -r public/assets ../dist/public/assets",
    "start": "node dist/server.js",
    "import-tileset": "tsx scripts/import-tileset.ts",
    "extract-furniture": "tsx scripts/extract-furniture.ts"
  },
  "dependencies": {
    "chokidar": "^4.0.0",
    "express": "^5.0.0",
    "pngjs": "^7.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/pngjs": "^6.0.5",
    "@types/ws": "^8.5.0",
    "concurrently": "^9.0.0",
    "esbuild": "^0.27.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.0"
  }
}
