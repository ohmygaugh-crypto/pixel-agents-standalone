{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "resolveJsonModule": true,
    "declaration": false
  },
  "include": ["server/**/*.ts", "scripts/**/*.ts", "playwright.config.ts", "tests/e2e/**/*.ts"],
  "exclude": ["node_modules", "dist", "webview-ui"]
}
